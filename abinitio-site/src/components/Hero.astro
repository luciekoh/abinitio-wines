---
import { getImage } from 'astro:assets';
import heroPhoto from '../assets/images/photos/emmanuel-roblin-vineyard.jpg';
import logoImg from '../assets/images/logo/logo-ab-initio-clean.png';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? enT : frT;
const optimizedHero = await getImage({ src: heroPhoto, format: 'webp', quality: 82, width: 1600 });

const srHeading = lang === 'en'
  ? 'AB Initio — Organic wines aged in amphora, Muscadet Nantais, Loire Valley'
  : 'Ab Initio — Vins biologiques élevés en amphore, Muscadet nantais, Loire Valley';
const logoAlt = lang === 'en' ? 'AB Initio — Organic wines, Loire' : 'Ab Initio — Vins biologiques, Loire';
const scrollAria = lang === 'en' ? 'Discover — scroll to content' : 'Découvrir — défiler vers le contenu';
---

<section class="hero">
  <div class="hero-image" style={`background-image: url('${optimizedHero.src}')`}></div>
  <div class="hero-content">
    <h1 class="sr-only">{srHeading}</h1>
    <img class="hero-logo-img" src={logoImg.src} alt={logoAlt} />
    <div class="hero-motto">{t.homepage.heroEyebrow}</div>
    <div class="hero-subtitle">{t.homepage.heroTagline}</div>
  </div>
  <a href="#intro" class="hero-scroll" aria-label={scrollAria}>
    <span>{t.homepage.heroCta}</span>
    <svg class="hero-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<script>
  document.querySelector('.hero-scroll')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('intro')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>

<style>
  .hero {
    height: 100vh;
    min-height: 600px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 8, .35) 0%,
      rgba(10, 10, 8, .12) 35%,
      rgba(10, 10, 8, .4) 65%,
      rgba(10, 10, 8, .9) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
    animation: heroIn 1.2s ease-out .3s both;
  }

  .hero-logo-img {
    height: clamp(60px, 12vw, 100px);
    filter: invert(1) brightness(2);
    margin-bottom: .5rem;
  }

  .hero-motto {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 400;
    font-style: italic;
    color: rgba(245, 242, 235, .9);
    letter-spacing: .2em;
    margin-top: .8rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, .5);
  }

  .hero-subtitle {
    font-family: var(--sans);
    font-size: clamp(.78rem, 1.3vw, .95rem);
    font-weight: 400;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: rgba(245, 242, 235, .7);
    margin-top: 2.5rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, .5);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .3rem;
    cursor: pointer;
  }

  .hero-scroll span {
    font-family: var(--sans);
    font-size: clamp(.65rem, 1vw, .75rem);
    letter-spacing: .25em;
    text-transform: uppercase;
    color: rgba(245, 242, 235, .55);
    transition: color .3s;
  }

  .hero-scroll:hover span {
    color: rgba(245, 242, 235, .85);
  }

  .hero-chevron {
    width: 20px;
    height: 20px;
    color: rgba(245, 242, 235, .45);
    animation: chevronBounce 2s ease-in-out infinite;
  }

  .hero-scroll:hover .hero-chevron {
    color: rgba(245, 242, 235, .8);
  }

  @keyframes chevronBounce {
    0%, 100% { transform: translateY(0); opacity: .4; }
    50%      { transform: translateY(6px); opacity: 1; }
  }
</style>
