---
import WineCard from './WineCard.astro';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

import philiaImg from '../assets/images/labels/philia.jpg';
import eidosImg from '../assets/images/labels/eidos.jpeg';
import logosImg from '../assets/images/labels/logos.jpg';
import kedronImg from '../assets/images/labels/kedron.jpg';
import kairosImg from '../assets/images/labels/kairos.jpeg';
import prestoImg from '../assets/images/labels/presto.jpg';
import ekkoImg from '../assets/images/labels/ekko.jpg';
import illicoImg from '../assets/images/labels/illico.jpg';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? enT : frT;
const wineBase = lang === 'en' ? '/en/wines' : '/cuvees';
const colorWhite = lang === 'en' ? 'White' : 'Blanc';
const colorRed = lang === 'en' ? 'Red' : 'Rouge';
const labelPrefix = lang === 'en' ? 'Label' : 'Étiquette';

const philosophie = [
  { name: 'PHILIA', vintage: '2021', color: colorWhite, grapes: 'Folle Blanche', imageSrc: philiaImg.src, altText: `${labelPrefix} Philia 2021 — Folle Blanche`, href: `${wineBase}/philia` },
  { name: 'EÏDOS', vintage: '2022', color: colorWhite, grapes: 'Melon B. · Chardonnay · Folle B.', imageSrc: eidosImg.src, altText: `${labelPrefix} Eïdos 2022 — Melon B., Chardonnay, Folle B.`, href: `${wineBase}/eidos` },
  { name: 'LOGOS', vintage: '2023', color: colorWhite, grapes: 'Chardonnay', imageSrc: logosImg.src, altText: `${labelPrefix} Logos 2023 — Chardonnay`, href: `${wineBase}/logos` },
  { name: 'KEDRON', vintage: '2020', color: colorRed, grapes: 'Grenache · Syrah', imageSrc: kedronImg.src, altText: `${labelPrefix} Kedron 2020 — Grenache, Syrah`, href: `${wineBase}/kedron` },
  { name: 'KAÏROS', vintage: '2021', color: colorRed, grapes: 'Gamay', imageSrc: kairosImg.src, altText: `${labelPrefix} Kaïros 2021 — Gamay`, href: `${wineBase}/kairos` },
];

const copains = [
  { name: 'PRESTO', vintage: '2023', color: colorWhite, grapes: 'Folle B. · Chardonnay · Melon B.', imageSrc: prestoImg.src, altText: `${labelPrefix} Presto 2023 — Folle B., Chardonnay, Melon B.`, href: `${wineBase}/presto` },
  { name: 'EKKO', vintage: '2023', color: colorWhite, grapes: 'Melon de Bourgogne', imageSrc: ekkoImg.src, altText: `${labelPrefix} Ekko 2023 — Melon de Bourgogne`, href: `${wineBase}/ekko` },
  { name: 'ILLICO', vintage: '2021', color: colorRed, grapes: 'Grenache · Syrah', imageSrc: illicoImg.src, altText: `${labelPrefix} Illico 2021 — Grenache, Syrah`, href: `${wineBase}/illico` },
];
---

<section class="wines-section" id="wines">
  <div class="wines-inner">
    <div class="wines-header fade-in">
      <span class="section-label wines-label">{t.homepage.collectionHeading}</span>
      <h2 class="wines-title" set:html={lang === 'en' ? 'Every name<br />is an intention.' : 'Chaque cuvée porte un nom<br />qui est une intention.'} />
    </div>

    <div class="wine-category">
      <div class="wine-category-header fade-in">
        <span class="wine-category-name">{t.homepage.philosophyLabel}</span>
        <span class="wine-category-desc">{t.homepage.philosophySub}</span>
      </div>
      <div class="wine-row stagger">
        {philosophie.map((wine) => (
          <WineCard {...wine} ctaLabel={t.homepage.wineCta} />
        ))}
      </div>
    </div>

    <div class="wine-category wine-category-last">
      <div class="wine-category-header fade-in">
        <span class="wine-category-name">{t.homepage.friendsLabel}</span>
        <span class="wine-category-desc">{t.homepage.friendsSub}</span>
      </div>
      <div class="wine-row stagger">
        {copains.map((wine) => (
          <WineCard {...wine} ctaLabel={t.homepage.wineCta} />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .wines-section {
    background: var(--black);
    color: var(--offwhite);
    padding-top: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .wines-inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .wines-header {
    margin-bottom: 3rem;
  }

  .wines-label {
    font-size: .7rem;
    color: rgba(245, 242, 235, .7);
  }

  .wines-title {
    font-family: var(--serif);
    font-size: clamp(2.1rem, 4.5vw, 3.4rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--offwhite);
  }

  .wine-category {
    margin-bottom: 4rem;
  }

  .wine-category-last {
    margin-bottom: 1rem;
  }

  .wine-category-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: .75rem;
    border-bottom: 1px solid rgba(245, 242, 235, .12);
  }

  .wine-category-name {
    font-family: var(--display);
    font-size: 1.6rem;
    letter-spacing: .1em;
    color: var(--offwhite);
  }

  .wine-category-desc {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(245, 242, 235, .65);
  }

  .wine-row {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .wine-row::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 900px) {
    .wine-row {
      overflow: visible;
      flex-wrap: wrap;
    }
  }

  @media (max-width: 600px) {
    .wine-category-header {
      flex-direction: column;
      gap: .3rem;
    }
  }
</style>
