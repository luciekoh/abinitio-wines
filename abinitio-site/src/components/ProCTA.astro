---
import partnersData from '../content/partners/list.json';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? enT : frT;
const partners = partnersData.items;
const findHref = lang === 'en' ? '/en/find-our-wines' : '/trouver-nos-vins';
---

<!-- Part A: CTA band -->
<div class="pro-cta" id="pro">
  <div class="pro-cta-inner fade-in">
    <div class="pro-cta-text">
      <h3 class="pro-heading">{t.homepage.ctaHeading}</h3>
      <p class="pro-subtitle">{t.homepage.ctaSub}</p>
    </div>
    <a href="mailto:contact@abinitio-wines.com" class="pro-btn">{t.homepage.ctaButton}</a>
  </div>
</div>

<!-- Part B: Trust strip -->
<div class="trust-strip">
  <div class="trust-inner fade-in">
    <span class="trust-header">{t.homepage.trustEyebrow}</span>
    <p class="trust-line">
      {partners.map((p) => (
        <span class="partner-unit">{p.name} <span class="place">{p.town}</span><span class="sep">·</span></span>
      ))}
      <span class="more">{t.homepage.trustEtAussi}</span>
    </p>
    <a href={findHref} class="section-cta trust-link">{t.homepage.trustLink}</a>
  </div>
</div>

<style>
  .pro-cta {
    background: var(--cta-bg);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 5vw, 4rem);
  }

  .pro-cta-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem 3rem;
    flex-wrap: wrap;
  }

  .pro-cta-text {
    flex: 1;
    min-width: 260px;
  }

  .pro-heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--cta-heading);
    margin-bottom: .5rem;
  }

  .pro-subtitle {
    font-family: var(--sans);
    font-size: .9rem;
    font-weight: 300;
    color: var(--cta-subtitle);
  }

  .pro-btn {
    display: inline-block;
    flex-shrink: 0;
    align-self: center;
    font-family: var(--sans);
    font-size: .72rem;
    font-weight: 400;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cta-bg);
    background: var(--offwhite);
    padding: .85rem 2.8rem;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: all .3s;
  }

  .pro-btn:hover {
    background: transparent;
    border-color: var(--offwhite);
    color: var(--offwhite);
  }

  .trust-strip {
    background: var(--cream);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 5vw, 4rem);
  }

  .trust-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .trust-header {
    display: block;
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 400;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-bottom: .8rem;
  }

  .trust-line {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    color: var(--accent);
    line-height: 2.1;
  }

  .partner-unit {
    display: inline;
  }

  .partner-unit .place {
    font-family: var(--sans);
    font-style: normal;
    font-size: .78rem;
    color: var(--mid-gray);
    letter-spacing: .04em;
    margin-left: .3em;
  }

  .partner-unit .sep {
    color: var(--accent);
    opacity: .45;
    margin: 0 .4rem 0 .8rem;
  }

  .trust-line .more {
    color: var(--mid-gray);
  }

  .trust-link {
    display: inline-block;
    margin-top: 1.2rem;
    color: var(--accent);
    opacity: .6;
  }
  .trust-link:hover {
    opacity: 1;
    border-bottom-color: var(--accent);
  }
</style>
