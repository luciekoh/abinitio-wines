---
import { getCollection } from 'astro:content';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;
const t = lang === 'en' ? enT : frT;
const eventsHref = lang === 'en' ? '/en/events' : '/salons';

const monthsFR = ['jan', 'fév', 'mars', 'avr', 'mai', 'juin', 'juil', 'août', 'sept', 'oct', 'nov', 'déc'];
const monthsEN = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const months = lang === 'en' ? monthsEN : monthsFR;

const allSalons = await getCollection('salons');
const today = new Date();
today.setHours(0, 0, 0, 0);
const upcoming = allSalons
  .filter(e => new Date(e.data.end_date) >= today)
  .sort((a, b) => new Date(a.data.start_date).getTime() - new Date(b.data.start_date).getTime())
  .slice(0, 3);

function formatRange(startDate: Date, endDate: Date): string {
  const s = new Date(startDate), e = new Date(endDate);
  const sameDay = s.toDateString() === e.toDateString();
  const sameMonth = s.getMonth() === e.getMonth() && s.getFullYear() === e.getFullYear();
  if (sameDay) return `${s.getDate()} ${months[s.getMonth()]}`.toUpperCase();
  if (sameMonth) return `${s.getDate()}–${e.getDate()} ${months[s.getMonth()]}`.toUpperCase();
  return `${s.getDate()} ${months[s.getMonth()]} – ${e.getDate()} ${months[e.getMonth()]}`.toUpperCase();
}

const countryMap: Record<string, string> = (t as any).countries || {};
function localizeCountry(c: string): string {
  return countryMap[c] || c;
}

function eventName(salon: any): string {
  if (lang === 'en' && salon.data.name_en) return salon.data.name_en;
  return salon.data.name;
}
---

<div class="events-strip" id="events">
  <div class="events-inner">
    <span class="section-label events-label">{t.homepage.eventsHeading}</span>
    <div class="events-list stagger">
      {upcoming.map((salon) => (
        <div class="event-item">
          <span class="event-date">{formatRange(salon.data.start_date, salon.data.end_date)}</span>
          <span class="event-name">{eventName(salon)}</span>
          <span class="event-location">{salon.data.city}, {localizeCountry(salon.data.country)}</span>
        </div>
      ))}
    </div>
    <a href={eventsHref} class="section-cta" style="margin-top:2.5rem;display:inline-block;color:var(--accent)">{t.homepage.eventsCta}</a>
  </div>
</div>

<style>
  .events-strip {
    background: #faf9f6;
    color: var(--dark-gray);
    padding: clamp(3rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    border-top: 1px solid rgba(44, 42, 38, .08);
  }

  .events-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .events-label {
    display: block;
    margin-bottom: 2rem;
    color: var(--mid-gray);
    font-size: .72rem;
  }

  .event-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(44, 42, 38, .1);
  }

  .event-date {
    font-family: var(--display);
    font-size: .95rem;
    letter-spacing: .08em;
    white-space: nowrap;
    min-width: 120px;
    color: var(--mid-gray);
  }

  .event-name {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--dark-gray);
  }

  .event-location {
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--mid-gray);
    margin-left: auto;
  }

  @media (max-width: 600px) {
    .event-item {
      flex-direction: column;
      gap: .2rem;
    }
  }
</style>
