---
import logoImg from '../assets/images/logo/logo-ab-initio-clean.png';
import euCertImg from '../assets/images/certs/eu-organic-leaf.png';
import abCertImg from '../assets/images/certs/ab-cert-bw.png';
---

<footer>
  <div class="footer-inner">
    <!-- Left column: Brand -->
    <div class="footer-brand">
      <img class="footer-logo-img" src={logoImg.src} alt="Ab Initio — Vins biologiques, Loire" />
      <p class="footer-motto">Nihil fit sine causa.</p>
      <div class="footer-cert-block">
        <span class="footer-cert-text">Agriculture Biologique FR-BIO-01 · Certifié ECOCERT</span>
        <div class="footer-certs">
          <img class="footer-cert-img footer-cert-ab" src={abCertImg.src} alt="Label Agriculture Biologique France" />
          <img class="footer-cert-img footer-cert-eu" src={euCertImg.src} alt="Label Agriculture Biologique européen" />
        </div>
      </div>
    </div>

    <!-- Center column: Contact -->
    <div class="footer-col footer-contact">
      <h4>Contact</h4>
      <p>Clos de l'Écu<br />44430 Le Landreau<br />France</p>
      <a href="mailto:contact@abinitio-wines.com">contact@abinitio-wines.com</a>
      <a href="tel:+33240064091">+33 (0)2 40 06 40 91</a>
    </div>

    <!-- Right column: Navigation -->
    <div class="footer-col footer-nav">
      <h4>Navigation</h4>
      <a href="/cuvees">Cuvées</a>
      <a href="/histoire">Histoire</a>
      <a href="/salons">Salons</a>
      <a href="/trouver-nos-vins">Trouver nos vins</a>
      <div class="footer-lang">
        <a href="#" class="lang-active">FR</a>
        <span class="lang-sep">/</span>
        <a href="#">EN</a>
      </div>
    </div>
  </div>

  <div class="footer-instagram-row">
    <a href="https://www.instagram.com/abinitio_wine/" class="footer-instagram" target="_blank" rel="noopener">Suivez-nous sur Instagram</a>
  </div>

  <div class="footer-bottom">
    <span class="footer-bottom-left">L'abus d'alcool est dangereux pour la santé. À consommer avec modération. · © 2026 SAS AB INITIO · <a href="/mentions-legales">Mentions légales</a> · <a href="/politique-de-confidentialite">Politique de confidentialité</a></span>
  </div>
</footer>

<style>
  footer {
    background: var(--black);
    color: var(--offwhite);
    padding: clamp(3rem, 6vw, 4rem) clamp(1.5rem, 5vw, 4rem) 0;
    border-top: 1px solid rgba(245, 242, 235, .06);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
  }

  /* Left: Brand — all #b8b2a6 warm gray */
  .footer-logo-img {
    height: 28px;
    filter: invert(78%) sepia(5%) saturate(400%) hue-rotate(15deg) brightness(90%);
    margin-bottom: .6rem;
  }

  .footer-motto {
    font-family: var(--serif);
    font-size: .85rem;
    font-weight: 300;
    font-style: italic;
    color: var(--warm-gray);
    margin-bottom: 2.5rem;
  }

  .footer-cert-block {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .footer-cert-text {
    display: block;
    font-family: var(--sans);
    font-size: .82rem;
    color: var(--warm-gray);
    line-height: 1.5;
  }

  .footer-certs {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    justify-content: flex-start;
  }

  .footer-cert-img {
    height: 55px;
  }

  .footer-cert-ab {
    filter: invert(1) brightness(2);
    opacity: .42;
  }

  .footer-cert-eu {
    filter: brightness(0) invert(1);
    opacity: .42;
  }

  /* Column headings */
  .footer-col h4 {
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 400;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-bottom: .8rem;
  }

  .footer-col a,
  .footer-col p {
    display: block;
    font-family: var(--sans);
    font-size: .82rem;
    font-weight: 300;
    color: var(--warm-gray);
    margin-bottom: .4rem;
    line-height: 1.5;
  }

  .footer-col a:hover {
    color: var(--offwhite);
  }

  /* Instagram — centered full-width */
  .footer-instagram-row {
    max-width: 1100px;
    margin: 2.5rem auto 0;
    text-align: center;
  }

  .footer-instagram {
    font-family: var(--sans);
    font-size: .66rem;
    font-weight: 400;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--warm-gray);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(184, 178, 166, .4);
    transition: color .3s, text-decoration-color .3s;
  }

  .footer-instagram:hover {
    color: var(--offwhite);
    text-decoration-color: var(--offwhite);
  }

  /* Right: Nav — right-aligned */
  .footer-nav {
    text-align: right;
  }

  .footer-nav a {
    text-align: right;
  }

  /* Language toggle */
  .footer-lang {
    margin-top: 1.2rem;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: .3rem;
  }

  .footer-lang a {
    display: inline;
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 400;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--warm-gray);
    opacity: .45;
    margin-bottom: 0;
    transition: opacity .3s;
  }

  .footer-lang a.lang-active {
    opacity: 1;
  }

  .footer-lang a:hover {
    opacity: 1;
    color: var(--offwhite);
  }

  .lang-sep {
    font-family: var(--sans);
    font-size: .65rem;
    color: rgba(245, 242, 235, .2);
  }

  /* Bottom strip */
  .footer-bottom {
    max-width: 1100px;
    margin: 1.5rem auto 0;
    padding: 1.2rem 0;
    border-top: 1px solid rgba(245, 242, 235, .06);
    text-align: center;
  }

  .footer-bottom span {
    font-family: var(--sans);
    font-size: .75rem;
    font-weight: 300;
    color: var(--warm-gray);
  }

  .footer-bottom-left a {
    color: var(--warm-gray);
    transition: color .3s;
  }

  .footer-bottom-left a:hover {
    color: var(--offwhite);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-nav {
      text-align: left;
    }

    .footer-nav a {
      text-align: left;
    }

    .footer-lang {
      justify-content: flex-start;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
