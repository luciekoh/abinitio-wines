---
interface Props {
  title?: string;
  description?: string;
  lang?: 'fr' | 'en';
  frPath?: string;
  enPath?: string;
}

const {
  lang = 'fr',
  frPath = '/',
  enPath = '/en/',
} = Astro.props;

const defaultTitle = lang === 'en'
  ? 'AB Initio — Organic wines from the Loire Valley, Muscadet'
  : 'Ab Initio — Vins biologiques, Muscadet nantais, Loire';
const defaultDescription = lang === 'en'
  ? 'AB Initio: artisanal organic wines from the Muscadet Nantais. Folle Blanche, Melon de Bourgogne, Chardonnay and Gamay vinified in amphoras and concrete by Emmanuel Roblin.'
  : 'Ab Initio, vins biologiques élevés en amphore. Folle Blanche, Melon de Bourgogne, Chardonnay, Gamay. Vignoble du Muscadet nantais entre Loire et Bretagne. Certifié agriculture biologique ECOCERT.';

const { title = defaultTitle, description = defaultDescription } = Astro.props;

const siteOrigin = (Astro.site && Astro.site.origin) || 'https://www.abinitio-wines.com';
const frUrl = `${siteOrigin}${frPath}`;
const enUrl = `${siteOrigin}${enPath}`;

const privacyUrl = lang === 'en' ? '/en/privacy-policy' : '/politique-de-confidentialite';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light only" />
  <meta name="supported-color-schemes" content="light only" />
  <meta name="description" content={description} />
  <meta name="google-site-verification" content="5Ot_bwAJjeZY3Y4-SszuNRtjKGCan_iuDBne3j7Ddd8" />
  <title>{title}</title>

  <link rel="alternate" hreflang="fr" href={frUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="x-default" href={frUrl} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Bebas+Neue&display=swap" rel="stylesheet" />

  <!-- Tarteaucitron (cookie consent) -->
  <script is:inline src="/tarteaucitron/tarteaucitron.js"></script>
  <script is:inline define:vars={{ privacyUrl }}>
    tarteaucitron.init({
      "privacyUrl": privacyUrl,
      "bodyPosition": "bottom",
      "hashtag": "#tarteaucitron",
      "cookieName": "tarteaucitron",
      "orientation": "bottom",
      "groupServices": false,
      "showDetailsOnClick": true,
      "serviceDefaultState": "wait",
      "showAlertSmall": false,
      "cookieslist": false,
      "showIcon": true,
      "iconPosition": "BottomRight",
      "highPrivacy": true,
      "handleBrowserDNTRequest": false,
      "removeCredit": true,
      "moreInfoLink": true,
      "readmoreLink": privacyUrl,
      "mandatory": false,
      "mandatoryCta": true
    });
  </script>

  <!-- GA4 via tarteaucitron -->
  <script is:inline>
    tarteaucitron.user.gtagUa = 'G-XWTNVDDGWW';
    (tarteaucitron.job = tarteaucitron.job || []).push('gtag');
  </script>

  <!-- Microsoft Clarity via tarteaucitron -->
  <script is:inline>
    tarteaucitron.user.clarityId = 'wh6p7x4mfw';
    (tarteaucitron.job = tarteaucitron.job || []).push('clarity');
  </script>

  <!-- GTM via tarteaucitron -->
  <script is:inline>
    tarteaucitron.user.googletagmanagerId = 'GTM-WP5BMJ26';
    (tarteaucitron.job = tarteaucitron.job || []).push('googletagmanager');
  </script>

  <!-- Tarteaucitron style overrides -->
  <style is:global>
    #tarteaucitronRoot #tarteaucitronAlertBig {
      background: #111110 !important;
      border-top: 0.5px solid rgba(245, 240, 232, 0.08) !important;
      font-family: 'DM Sans', sans-serif !important;
      color: rgba(245, 240, 232, 0.55) !important;
      font-size: 12.5px !important;
    }

    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronDisclaimerAlert,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronDisclaimerAlert span {
      font-family: 'DM Sans', sans-serif !important;
      color: rgba(245, 240, 232, 0.55) !important;
      font-size: 12.5px !important;
    }

    #tarteaucitronRoot #tarteaucitronAlertBig button,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronCloseAlert,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronPersonalize,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronPersonalize2,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronAllDenied,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronAllDenied2 {
      appearance: none !important;
      -webkit-appearance: none !important;
      border-radius: 0 !important;
      background: #111110 !important;
      color: #f5f0e8 !important;
      border: 0.5px solid rgba(245, 240, 232, 0.5) !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 12px !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em !important;
      padding: 8px 16px !important;
      text-transform: none !important;
      cursor: pointer;
      transition: background 0.3s, color 0.3s;
    }

    #tarteaucitronRoot #tarteaucitronAlertBig button:hover,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronCloseAlert:hover,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronPersonalize:hover,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronPersonalize2:hover,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronAllDenied:hover,
    #tarteaucitronRoot #tarteaucitronAlertBig #tarteaucitronAllDenied2:hover {
      background: #f5f0e8 !important;
      color: #111110 !important;
    }

    #tarteaucitronRoot #tarteaucitronAlertBig a#tarteaucitronPrivacyUrl,
    #tarteaucitronRoot #tarteaucitronAlertBig .tarteaucitronAlertBigBottom a {
      color: rgba(245, 240, 232, 0.3) !important;
      font-size: 11px !important;
      text-decoration: underline !important;
    }
  </style>

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Ab Initio",
    "alternateName": "SAS AB INITIO",
    "url": "https://www.abinitio-wines.com",
    "logo": "https://www.abinitio-wines.com/images/logo-ab-initio.png",
    "description": "Vins biologiques élevés en amphore, Muscadet nantais, Loire Valley",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Clos de l'Écu",
      "addressLocality": "Le Landreau",
      "postalCode": "44430",
      "addressCountry": "FR"
    },
    "telephone": "+33240064091",
    "email": "contact@abinitio-wines.com",
    "sameAs": ["https://www.instagram.com/abinitio_wine/"],
    "founder": {
      "@type": "Person",
      "name": "Emmanuel Roblin",
      "jobTitle": "Vigneron"
    },
    "knowsAbout": ["organic wine", "amphora winemaking", "natural wine", "Loire Valley wines"],
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "certification",
      "name": "Agriculture Biologique FR-BIO-01 ECOCERT"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Ab Initio — Vins Biologiques",
    "url": "https://www.abinitio-wines.com",
    "inLanguage": ["fr", "en"]
  })} />
</head>
<body>
  <slot />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in, .stagger').forEach((el) => observer.observe(el));
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
