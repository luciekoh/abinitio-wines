---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import enT from '../../i18n/en.json';

const t = enT;
const lang = 'en';
const frPath = '/mentions-legales/';
const enPath = '/en/legal-notice/';
---

<Base title="Legal notice — AB Initio" description="AB Initio legal notice — organic wines, Loire Valley." lang={lang} frPath={frPath} enPath={enPath}>
  <Nav lang={lang} frPath={frPath} enPath={enPath} />
  <main class="legal-page">
    <h1>{t.legalPage.title}</h1>

    <h2>{t.legalPage.publisherHeading}</h2>
    <p>
      SAS AB INITIO<br />
      Clos de l'Écu, 44430 Le Landreau, France<br />
      SIRET: 888 783 475 200 16<br />
      VAT no.: FR86 887834752<br />
      <a href="mailto:contact@abinitio-wines.com">contact@abinitio-wines.com</a><br />
      <a href="tel:+33240064091">+33 (0)2 40 06 40 91</a><br />
      {t.legalPage.publisherDirectorLabel}: Emmanuel Roblin
    </p>

    <h2>{t.legalPage.hostingHeading}</h2>
    <p>OVH SAS, 2 rue Kellermann, 59100 Roubaix, France</p>

    <h2>{t.legalPage.ipHeading}</h2>
    <p>{t.legalPage.ipBody}</p>

    <h2>{t.legalPage.photoHeading}</h2>
    <p>{t.legalPage.photoBody}</p>
  </main>
  <Footer lang={lang} frPath={frPath} enPath={enPath} />
</Base>

<style>
  .legal-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
    font-family: var(--sans);
    color: var(--dark-gray);
  }

  .legal-page h1 {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 300;
    margin-bottom: 3rem;
    color: var(--dark-gray);
  }

  .legal-page h2 {
    font-family: var(--sans);
    font-size: .65rem;
    font-weight: 400;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-top: 2.5rem;
    margin-bottom: .8rem;
  }

  .legal-page p {
    font-size: .88rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--mid-gray);
    margin-bottom: 1rem;
  }

  .legal-page a {
    color: var(--dark-gray);
    border-bottom: 1px solid transparent;
    transition: border-color .3s;
  }

  .legal-page a:hover {
    border-bottom-color: var(--dark-gray);
  }
</style>
