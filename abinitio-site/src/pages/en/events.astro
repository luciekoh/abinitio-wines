---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SeoBreadcrumbs from '../../components/SeoBreadcrumbs.astro';
import featuredBg from '../../assets/images/photos/ile-dyeu-inspiration.jpg';
import { getCollection } from 'astro:content';
import enT from '../../i18n/en.json';

const t = enT;
const lang = 'en';
const frPath = '/salons/';
const enPath = '/en/events/';

const allSalons = await getCollection('salons');
const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = allSalons
  .filter(e => new Date(e.data.end_date) >= today)
  .sort((a, b) => new Date(a.data.start_date).getTime() - new Date(b.data.start_date).getTime());

const past = allSalons
  .filter(e => new Date(e.data.end_date) < today)
  .sort((a, b) => new Date(b.data.start_date).getTime() - new Date(a.data.start_date).getTime());

const featured = upcoming[0];
const restUpcoming = upcoming.slice(1);

const pastByYear = past.reduce<Record<string, typeof past>>((acc, salon) => {
  const year = String(new Date(salon.data.start_date).getFullYear());
  if (!acc[year]) acc[year] = [];
  acc[year].push(salon);
  return acc;
}, {});
const pastYears = Object.keys(pastByYear).sort((a, b) => parseInt(b) - parseInt(a));

const monthsEN = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function formatRange(startISO: Date, endISO: Date, includeYear = true): string {
  const s = new Date(startISO), e = new Date(endISO);
  const sameDay = s.toDateString() === e.toDateString();
  const sameMonth = s.getMonth() === e.getMonth() && s.getFullYear() === e.getFullYear();
  const yearStr = includeYear ? ` ${s.getFullYear()}` : '';
  if (sameDay) return `${monthsEN[s.getMonth()]} ${s.getDate()}${yearStr}`;
  if (sameMonth) return `${monthsEN[s.getMonth()]} ${s.getDate()}–${e.getDate()}${yearStr}`;
  return `${monthsEN[s.getMonth()]} ${s.getDate()} – ${monthsEN[e.getMonth()]} ${e.getDate()}${yearStr}`;
}

function shortRange(startISO: Date, endISO: Date): string {
  return formatRange(startISO, endISO, false);
}

function tagLabel(type: string): string {
  if (type === 'pro') return t.eventsPage.tagPro;
  if (type === 'public') return t.eventsPage.tagPublic;
  if (type === 'mixte') return t.eventsPage.tagMixed;
  return type;
}

const countryMap: Record<string, string> = t.countries;
function localizeCountry(c: string): string {
  return countryMap[c] || c;
}

function eventName(salon: any): string {
  return salon.data.name_en || salon.data.name;
}

function rdvMailto(name: string): string {
  const subject = encodeURIComponent(`Meeting at ${name}`);
  return `mailto:contact@abinitio-wines.com?subject=${subject}`;
}
---

<Base title="Events — Where to find AB Initio wines, 2026 season" description="Find AB Initio at wine fairs and events in 2026: RAW WINE Tokyo, Sous les Pavés la Vigne Paris, and more." lang={lang} frPath={frPath} enPath={enPath}>
  <Nav lang={lang} frPath={frPath} enPath={enPath} />
  <SeoBreadcrumbs items={[
    { name: 'Home', url: '/en/' },
    { name: 'Events', url: '/en/events' },
  ]} />

  <section class="opener">
    <h1>{t.eventsPage.eyebrow}</h1>
    <p class="subtitle">{t.eventsPage.subtitle}</p>
  </section>

  {featured && (
    <section class="featured" style={`--featured-bg: url('${featuredBg.src}')`}>
      <div class="featured-inner">
        <div>
          <div class="label">{t.eventsPage.featuredLabel}</div>
          <div class="featured-date">{formatRange(featured.data.start_date, featured.data.end_date)}</div>
          <div class="featured-tag">{tagLabel(featured.data.type)}</div>
        </div>
        <div>
          <h2>{eventName(featured)}</h2>
          <p class="venue">{featured.data.city}{featured.data.country !== 'France' ? `, ${localizeCountry(featured.data.country)}` : ''}</p>

          {featured.data.notes && (
            <div class="notes" set:html={featured.data.notes_en || featured.data.notes} />
          )}

          <div class="cta-row">
            <a href={rdvMailto(eventName(featured))} class="btn btn-primary">{t.eventsPage.bookMeeting}</a>
            {featured.data.url && (
              <a href={featured.data.url} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">{t.eventsPage.eventWebsite}</a>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {!featured && (
    <section class="featured-empty">
      <p>{t.eventsPage.emptyCalendar}</p>
    </section>
  )}

  {restUpcoming.length > 0 && (
    <section class="upcoming">
      <div class="upcoming-inner">
        <div class="mini-header"><span class="eyebrow">{t.eventsPage.upcomingLabel}</span></div>
        <div class="events-list">
          {restUpcoming.map(salon => (
            salon.data.url ? (
              <a href={salon.data.url} target="_blank" rel="noopener noreferrer" class="event">
                <div class="event-date">{formatRange(salon.data.start_date, salon.data.end_date)}</div>
                <div class="event-name">
                  {eventName(salon)}
                  <span class="place">{salon.data.city}, {localizeCountry(salon.data.country)}</span>
                </div>
                <div class="event-tag">{tagLabel(salon.data.type)}</div>
              </a>
            ) : (
              <div class="event event-no-link">
                <div class="event-date">{formatRange(salon.data.start_date, salon.data.end_date)}</div>
                <div class="event-name">
                  {eventName(salon)}
                  <span class="place">{salon.data.city}, {localizeCountry(salon.data.country)}</span>
                </div>
                <div class="event-tag">{tagLabel(salon.data.type)}</div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="salons-cta">
    <div class="salons-cta-inner">
      <div>
        <h3>{t.eventsPage.noticeHeading}</h3>
        <p>{t.eventsPage.noticeSub}</p>
      </div>
      <a href="mailto:contact@abinitio-wines.com" class="btn-pro">{t.eventsPage.noticeCta}</a>
    </div>
  </section>

  {pastYears.length > 0 && (
    <section class="archive">
      <div class="archive-inner">
        <div class="mini-header"><span class="eyebrow">{t.eventsPage.archiveLabel}</span></div>
        {pastYears.map(year => (
          <div class="year-row">
            <div class="year-num">{year}</div>
            <div class="events-inline">
              {pastByYear[year].map((salon, i) => (
                <>
                  {salon.data.url ? (
                    <a href={salon.data.url} target="_blank" rel="noopener noreferrer" class="archive-link">{eventName(salon)}</a>
                  ) : (
                    <span>{eventName(salon)}</span>
                  )}
                  <span class="place">{salon.data.city}, {shortRange(salon.data.start_date, salon.data.end_date)}</span>
                  {i < pastByYear[year].length - 1 && <span class="sep">·</span>}
                </>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <Footer lang={lang} frPath={frPath} enPath={enPath} />
</Base>

<style>
  /* Opener */
  .opener {
    background: var(--offwhite);
    padding: clamp(5rem, 8vw, 7rem) 2rem clamp(2rem, 4vw, 3rem);
    text-align: center;
  }
  .opener h1 {
    font-family: var(--display);
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    letter-spacing: .08em;
    line-height: 1;
    color: var(--black);
    margin-bottom: .8rem;
  }
  .opener .subtitle {
    font-family: var(--sans);
    font-size: .72rem;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--mid-gray);
  }

  /* Featured */
  .featured {
    color: var(--offwhite);
    padding: 5rem 3rem 5.5rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(rgba(15, 22, 40, .25), rgba(15, 22, 40, .35)),
      var(--featured-bg) center/cover;
  }
  .featured-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: .85fr 1.15fr;
    gap: 5rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }
  .featured .label {
    font-family: var(--sans);
    font-size: .7rem;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--offwhite);
    margin-bottom: 1.6rem;
    opacity: .85;
  }
  .featured-date {
    font-family: var(--sans);
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--offwhite);
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .featured-tag {
    font-family: var(--sans);
    font-size: .78rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--offwhite);
    opacity: .75;
    margin-top: .6rem;
  }
  .featured h2 {
    font-family: var(--display);
    font-size: clamp(2.6rem, 4.6vw, 4rem);
    line-height: 1;
    letter-spacing: .03em;
    margin-bottom: 1rem;
  }
  .featured .venue {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--warm-gray);
    margin-bottom: 2.2rem;
  }
  .featured .notes {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--warm-gray);
    line-height: 1.6;
    margin-bottom: 2.4rem;
    padding-left: 1.4rem;
    border-left: 1px solid rgba(184, 178, 166, .3);
    max-width: 36em;
  }
  .featured .notes :global(p) { margin: 0; }

  .featured-empty {
    background: var(--offwhite);
    padding: 4rem 3rem;
    text-align: center;
    font-family: var(--serif);
    font-style: italic;
    color: var(--mid-gray);
    font-size: 1.15rem;
  }

  /* Buttons */
  .cta-row {
    margin-top: 2rem;
    display: flex;
    gap: 1.4rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--sans);
    font-size: .78rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    padding: 1.1rem 2.2rem;
    transition: all .2s;
    display: inline-block;
  }
  .btn-primary {
    background: var(--offwhite);
    color: var(--accent);
    border: 1px solid var(--offwhite);
  }
  .btn-primary:hover { background: transparent; color: var(--offwhite); }
  .btn-ghost {
    background: transparent;
    color: var(--offwhite);
    border: 1px solid rgba(245, 242, 235, .3);
  }
  .btn-ghost:hover { border-color: var(--offwhite); }

  /* Mini section header */
  .mini-header {
    text-align: center;
    margin-bottom: 2.8rem;
  }
  .mini-header .eyebrow {
    font-family: var(--sans);
    font-size: .72rem;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* Upcoming list */
  .upcoming {
    background: var(--offwhite);
    padding: 4.5rem 3rem 5rem;
  }
  .upcoming-inner { max-width: 1100px; margin: 0 auto; }
  .events-list { border-top: 1px solid var(--cream); }
  .event {
    display: grid;
    grid-template-columns: 1.1fr 2.4fr .8fr;
    gap: 2.5rem;
    align-items: center;
    padding: 1.8rem 1rem;
    border-bottom: 1px solid var(--cream);
    transition: background .2s;
    cursor: pointer;
    color: inherit;
  }
  .event-no-link { cursor: default; }
  .event:hover:not(.event-no-link) { background: rgba(237, 232, 221, .5); }
  .event:hover:not(.event-no-link) .event-name {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
  }
  .event-date {
    font-family: var(--sans);
    font-size: .92rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--mid-gray);
  }
  .event-name {
    font-family: var(--serif);
    font-size: 1.35rem;
    color: var(--accent);
    transition: text-decoration .2s;
  }
  .event-name .place {
    font-family: var(--sans);
    font-style: normal;
    font-size: .85rem;
    color: var(--mid-gray);
    display: block;
    margin-top: .2rem;
    letter-spacing: .02em;
    text-decoration: none !important;
  }
  .event-tag {
    font-family: var(--sans);
    font-size: .7rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--mid-gray);
    text-align: right;
  }

  /* Pro CTA */
  .salons-cta {
    background: var(--cta-bg);
    color: var(--offwhite);
    padding: 4rem 3rem;
  }
  .salons-cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .salons-cta h3 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin-bottom: .7rem;
    line-height: 1.2;
    color: var(--cta-heading);
  }
  .salons-cta p {
    font-family: var(--sans);
    font-weight: 300;
    color: var(--cta-subtitle);
    font-size: .95rem;
  }
  .salons-cta .btn-pro {
    justify-self: end;
    background: var(--offwhite);
    color: var(--cta-bg);
    border: 1px solid var(--offwhite);
    padding: 1.2rem 2.4rem;
    font-family: var(--sans);
    font-size: .78rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    transition: all .2s;
  }
  .salons-cta .btn-pro:hover { background: transparent; color: var(--offwhite); }

  /* Archive */
  .archive {
    background: var(--offwhite);
    padding: 4rem 3rem 5rem;
  }
  .archive-inner { max-width: 1100px; margin: 0 auto; }
  .year-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    align-items: baseline;
    padding: 1.4rem 0;
    border-top: 1px solid var(--cream);
  }
  .year-row:last-child { border-bottom: 1px solid var(--cream); }
  .year-num {
    font-family: var(--sans);
    font-size: 1.04rem;
    color: var(--mid-gray);
    letter-spacing: .04em;
  }
  .events-inline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--dark-gray);
  }
  .events-inline .archive-link {
    color: inherit;
    border-bottom: 1px solid transparent;
    transition: border-color .2s;
  }
  .events-inline .archive-link:hover {
    border-bottom-color: var(--accent);
  }
  .events-inline .place {
    font-family: var(--sans);
    font-style: normal;
    font-size: .78rem;
    color: var(--mid-gray);
    letter-spacing: .04em;
    margin-left: .3em;
  }
  .events-inline .sep {
    color: var(--accent);
    opacity: .5;
    margin: 0 .7rem;
  }

  /* Mobile */
  @media (max-width: 880px) {
    .opener, .featured, .upcoming, .archive, .salons-cta { padding-left: 1.2rem; padding-right: 1.2rem; }
    .opener { padding-bottom: 2.5rem; }
    .featured-inner { grid-template-columns: 1fr; gap: 2.4rem; }
    .event { grid-template-columns: 1fr; gap: .4rem; padding: 1.4rem .5rem; }
    .event-tag { text-align: left; margin-top: .3rem; }
    .year-row { grid-template-columns: 1fr; gap: .4rem; }
    .salons-cta-inner { grid-template-columns: 1fr; gap: 1.6rem; }
    .salons-cta .btn-pro { justify-self: start; }
  }
</style>
