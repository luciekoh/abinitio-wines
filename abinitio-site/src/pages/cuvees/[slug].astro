---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SeoBreadcrumbs from '../../components/SeoBreadcrumbs.astro';

// Wine order for prev/next navigation
const wineOrder = ['philia', 'eidos', 'logos', 'kedron', 'kairos', 'presto', 'ekko', 'illico'];

const wineDisplayNames: Record<string, string> = {
  philia: 'Philia', eidos: 'Eïdos', logos: 'Logos', kedron: 'Kedron',
  kairos: 'Kaïros', presto: 'Presto', ekko: 'Ekko', illico: 'Illico',
};

export async function getStaticPaths() {
  const wines = await getCollection('wines');
  return wines.map((wine) => ({
    params: { slug: wine.id },
    props: { wine: wine.data },
  }));
}

const { slug } = Astro.params;
const { wine } = Astro.props;

// Prev/next
const currentIdx = wineOrder.indexOf(slug!);
const prevSlug = wineOrder[(currentIdx - 1 + wineOrder.length) % wineOrder.length];
const nextSlug = wineOrder[(currentIdx + 1) % wineOrder.length];
const prevName = wineDisplayNames[prevSlug];
const nextName = wineDisplayNames[nextSlug];

// Import images dynamically
const bottleImages = import.meta.glob('/src/assets/images/bottles/*.{jpg,jpeg,png}', { eager: true });
const labelImages = import.meta.glob('/src/assets/images/labels/*.{jpg,jpeg,png}', { eager: true });

const bottleKey = `/src/assets/images/bottles/${slug}.jpg`;
const bottleImg = (bottleImages[bottleKey] as any)?.default;
// Label fallback — try .jpg then .jpeg
const labelImg = (labelImages[`/src/assets/images/labels/${slug}.jpg`] as any)?.default
  || (labelImages[`/src/assets/images/labels/${slug}.jpeg`] as any)?.default;
const heroImg = bottleImg || labelImg;

const categoryLabel = wine.category === 'philosophie'
  ? 'VINS DE LA PHILOSOPHIE'
  : 'VINS DES COPAINS';
const colorLabel = wine.color === 'blanc' ? 'BLANC' : 'ROUGE';

// Extract élevage info from vinification text
const vinifFr = wine.vinification.fr;
const elevageMatch = vinifFr.match(/Élevage en (.+?)\./);
const elevage = elevageMatch ? elevageMatch[1] : '';

// Certification display
const certDisplay = wine.certification.toLowerCase().includes('biodynami')
  ? 'Biologique et biodynamique · Certifié ECOCERT'
  : 'Biologique · Certifié ECOCERT';

// Vinification summary as dot-separated line
const vinifParts = [
  'Vendanges manuelles',
  ...vinifFr.split('. ').filter(s => s && !s.startsWith('Les raisins') && !s.startsWith('Raisins égrappés')).map(s => s.replace(/\.$/, ''))
];
// Build from source fields
const vinifSummary = vinifFr
  .replace(/\.$/, '')
  .split('. ')
  .filter(Boolean)
  .join(' · ');

// SEO
const pageTitle = `${wine.name} ${wine.vintage} — ${wine.grapes.split(',')[0].trim()} · Ab Initio`;
const pageDesc = `${wine.slogan.fr}. ${wine.about.fr.substring(0, 150)}...`;

// Parse accords — separate pairings from serving temp
const tableText = wine.table.fr;
const pairings = tableText
  .split(/\.\s+/)
  .map((s: string) => s.replace(/\.$/, '').trim())
  .filter((s: string) => s && !s.startsWith('Servir'));

// Terroir short
const terroirShort = wine.terroir.split(' / ').pop() || wine.terroir;

// Tech sheets
const wineName = wine.name.charAt(0) + wine.name.slice(1).toLowerCase();
const techSheets = [
  { label: `Fiche technique ${wineName} ${wine.vintage}`, url: `/techsheets/${slug}-${wine.vintage}-fr.pdf` },
  ...(slug === 'logos' ? [{ label: `Fiche technique ${wineName} ${wine.vintage} (18 mois)`, url: `/techsheets/logos-2023-18m-fr.pdf` }] : []),
];
---

<Base title={pageTitle} description={pageDesc}>
  <Nav />

  <SeoBreadcrumbs items={[
    { name: 'Accueil', url: '/' },
    { name: 'Cuvées', url: '/cuvees' },
    { name: `${wine.name} ${wine.vintage}`, url: `/cuvees/${slug}` },
  ]} />

  <!-- Hero Split -->
  <section class="wine-hero">
    <div class="wine-hero-left">
      {heroImg && <img src={heroImg.src} alt={`Bouteille ${wine.name} ${wine.vintage}`} class="wine-bottle" />}
    </div>
    <div class="wine-hero-right">
      <span class="wine-category-badge">{categoryLabel} · {colorLabel}</span>
      <p class="wine-slogan">{wine.slogan.fr}</p>
      <h1 class="wine-title">{wine.name}</h1>
      <p class="wine-vintage-label">{wine.vintage}</p>
      <p class="wine-grapes-detail">{wine.grapes}</p>
      <div class="wine-data-row">
        <div class="wine-data-point">
          <span class="wine-data-label">Terroir</span>
          <span class="wine-data-value">{terroirShort}</span>
        </div>
        <div class="wine-data-point">
          <span class="wine-data-label">Élevage</span>
          <span class="wine-data-value">{elevage || '—'}</span>
        </div>
        <div class="wine-data-point">
          <span class="wine-data-label">Agriculture</span>
          <span class="wine-data-value">{certDisplay}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="wine-story">
    <div class="wine-story-inner">
      <span class="section-label">L'histoire de cette cuvée</span>
      <p class="wine-story-text">{wine.about.fr}</p>
      {wine.nameMeaning && (
        <p class="wine-name-meaning">{wine.name} — {wine.nameMeaning.fr}</p>
      )}
    </div>
  </section>

  <!-- Tasting + Pairing -->
  <section class="wine-tasting">
    <div class="wine-tasting-inner">
      <span class="section-label wine-tasting-label">Dégustation</span>
      <p class="wine-tasting-text">{wine.degustation.fr}</p>
      <span class="section-label wine-accords-label">Accords</span>
      <ul class="wine-pairing-list">
        {pairings.map((p) => (
          <li>{p}</li>
        ))}
      </ul>
      <p class="wine-serving">Servir frais, environ {wine.servir}</p>
    </div>
  </section>

  <!-- Vinification -->
  <section class="wine-vinification">
    <div class="wine-vinification-inner">
      <span class="section-label">Vinification</span>
      <p class="wine-vinif-summary">{vinifSummary}</p>
    </div>
  </section>

  <!-- Download -->
  <section class="wine-download">
    <div class="wine-download-inner">
      <span class="section-label" style="display:block;margin-bottom:.5rem">Télécharger</span>
      {techSheets.map((sheet) => (
        <a href={sheet.url} class="wine-pdf-link" target="_blank" rel="noopener">
          <svg class="pdf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="18" x2="12" y2="12"></line>
            <line x1="9" y1="15" x2="12" y2="18"></line>
            <line x1="15" y1="15" x2="12" y2="18"></line>
          </svg>
          {sheet.label}
        </a>
      ))}
    </div>
  </section>

  <!-- B2B CTA -->
  <div class="wine-cta">
    <div class="wine-cta-inner">
      <div class="wine-cta-text">
        <h3>Ce vin vous intéresse ?</h3>
        <p>Tarifs et conditions pour les professionnels.</p>
      </div>
      <a href="mailto:contact@abinitio-wines.com" class="wine-cta-btn">Nous contacter</a>
    </div>
  </div>

  <!-- Prev/Next -->
  <div class="wine-prevnext">
    <div class="wine-prevnext-inner">
      <a href={`/cuvees/${prevSlug}`} class="wine-prev">← {prevName}</a>
      <a href={`/cuvees/${nextSlug}`} class="wine-next">{nextName} →</a>
    </div>
  </div>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": `${wine.name} ${wine.vintage}`,
    "brand": { "@type": "Brand", "name": "Ab Initio" },
    "description": `${wine.slogan.fr}. ${wine.about.fr.substring(0, 200)}`,
    "category": "Wine",
    "material": wine.grapes,
    "manufacturer": {
      "@type": "Organization",
      "name": "SAS AB INITIO",
      "address": { "addressLocality": "Le Landreau", "addressCountry": "FR" }
    }
  })} />

  <Footer />
</Base>

<style>
  /* Hero Split */
  .wine-hero {
    display: grid;
    grid-template-columns: 40% 60%;
    padding-top: clamp(4rem, 6vw, 5rem);
    background: var(--offwhite);
    align-items: center;
  }
  .wine-hero-left {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 0 0 0 clamp(1rem, 2vw, 1.5rem);
  }
  .wine-bottle {
    max-height: 74vh;
    max-width: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  .wine-hero-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(.8rem, 1.5vw, 1.2rem) clamp(1.5rem, 3vw, 2.5rem);
  }
  .wine-category-badge {
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 400;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-bottom: .8rem;
  }
  .wine-slogan {
    font-family: var(--serif);
    font-size: .95rem;
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
    margin-bottom: .5rem;
  }
  .wine-title {
    font-family: var(--display);
    font-size: clamp(2.2rem, 5vw, 2.8rem);
    letter-spacing: .06em;
    color: var(--dark-gray);
    margin-bottom: .2rem;
  }
  .wine-vintage-label {
    font-family: var(--serif);
    font-size: .95rem;
    font-weight: 300;
    color: var(--mid-gray);
    margin-bottom: .8rem;
  }
  .wine-grapes-detail {
    font-family: var(--sans);
    font-size: .82rem;
    font-weight: 400;
    color: var(--dark-gray);
    margin-bottom: 1.2rem;
  }
  .wine-data-row {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .wine-data-point {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .wine-data-label {
    font-family: var(--sans);
    font-size: .6rem;
    font-weight: 400;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--mid-gray);
  }
  .wine-data-value {
    font-family: var(--sans);
    font-size: .78rem;
    font-weight: 400;
    color: var(--dark-gray);
    line-height: 1.4;
  }

  /* Story */
  .wine-story {
    background: #faf9f6;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 5vw, 4rem);
  }
  .wine-story-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .wine-story-text {
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 300;
    color: var(--mid-gray);
    line-height: 1.8;
  }
  .wine-name-meaning {
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 400;
    font-style: italic;
    color: var(--wine-gold);
    margin-top: 1.5rem;
  }

  /* Tasting */
  .wine-tasting {
    background: var(--black);
    color: var(--offwhite);
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 5vw, 4rem);
  }
  .wine-tasting-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .wine-tasting-label {
    color: rgba(245, 242, 235, .85);
  }
  .wine-tasting-text {
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 300;
    color: rgba(245, 242, 235, .7);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .wine-accords-label {
    color: rgba(245, 242, 235, .85);
  }
  .wine-pairing-list {
    list-style: none;
    padding: 0;
  }
  .wine-pairing-list li {
    font-family: var(--serif);
    font-size: .97rem;
    font-weight: 300;
    color: rgba(245, 242, 235, .7);
    line-height: 1.8;
    padding-left: 1.2rem;
    position: relative;
  }
  .wine-pairing-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--wine-gold);
    font-weight: 600;
  }
  .wine-serving {
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 300;
    color: rgba(245, 242, 235, .7);
    margin-top: 1.5rem;
  }

  /* Vinification */
  .wine-vinification {
    background: #faf9f6;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 5vw, 4rem) clamp(1rem, 2vw, 1.5rem);
  }
  .wine-vinification-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .wine-vinif-summary {
    font-family: var(--serif);
    font-size: .97rem;
    font-weight: 300;
    color: var(--mid-gray);
    line-height: 1.8;
  }

  /* Download */
  .wine-download {
    background: #faf9f6;
    padding: 0 clamp(1.5rem, 5vw, 4rem) clamp(2rem, 4vw, 3.5rem);
  }
  .wine-download-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .wine-pdf-link {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-family: var(--sans);
    font-size: .78rem;
    font-weight: 400;
    color: var(--dark-gray);
    margin-top: .8rem;
    padding-bottom: .2rem;
    border-bottom: 1px solid transparent;
    transition: border-color .3s;
  }
  .wine-pdf-link:hover {
    border-bottom-color: var(--dark-gray);
  }
  .pdf-icon {
    color: var(--mid-gray);
  }

  /* B2B CTA */
  .wine-cta {
    background: var(--cta-bg);
    padding: clamp(3rem, 5vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
  }
  .wine-cta-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .wine-cta-text {
    flex: 1;
    min-width: 260px;
  }
  .wine-cta-text h3 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 300;
    color: var(--cta-heading);
    margin-bottom: .5rem;
  }
  .wine-cta-text p {
    font-family: var(--sans);
    font-size: .94rem;
    font-weight: 300;
    color: var(--cta-subtitle);
  }
  .wine-cta-btn {
    display: inline-block;
    font-family: var(--sans);
    font-size: .8rem;
    font-weight: 400;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cta-bg);
    background: var(--offwhite);
    padding: 1rem 3.2rem;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: all .3s;
    flex-shrink: 0;
  }
  .wine-cta-btn:hover {
    background: transparent;
    border-color: var(--offwhite);
    color: var(--offwhite);
  }

  /* Prev/Next */
  .wine-prevnext {
    background: var(--offwhite);
    padding: clamp(.8rem, 1.5vw, 1.2rem) clamp(1.5rem, 5vw, 4rem);
  }
  .wine-prevnext-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
  }
  .wine-prev, .wine-next {
    font-family: var(--sans);
    font-size: .82rem;
    font-weight: 400;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--mid-gray);
    padding-bottom: .2rem;
    border-bottom: 1px solid transparent;
    transition: all .3s;
  }
  .wine-prev:hover, .wine-next:hover {
    color: var(--dark-gray);
    border-bottom-color: var(--dark-gray);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .wine-hero {
      grid-template-columns: 1fr;
    }
    .wine-hero-right {
      order: -1;
    }
    .wine-hero-left {
      padding: 1.5rem;
    }
    .wine-bottle {
      max-height: 80vh;
    }
    .wine-cta-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
